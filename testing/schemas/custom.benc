define customtest;

var go_package = "github.com/alvarolm/benc/testing/custom";

# Form A — newtype aliases over base types (bencgen generates the type + codec)
custom Name   = string;
custom UserID = uint64;

# Form B — external codec package (you own the type + Size/Marshal/Unmarshal funcs)
custom Stamp {
    type   = "codecs.Stamp";
    import = "github.com/alvarolm/benc/testing/custom/codecs";
    funcs  = "github.com/alvarolm/benc/testing/custom/codecs";
}

ctr Record {
    Name name = 1;
    UserID id = 2;
    Stamp created = 3;
    []Name tags = 4;
    <Name, UserID> idx = 5;
    []Stamp stamps = 6;
}


# DO NOT EDIT.
# [meta_s]  [meta_e]