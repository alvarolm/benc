define fixedarrays;

var go_package = "github.com/alvarolm/benc/testing/fixedarrays";

custom Name = string;

ctr Point {
    int32 x = 1;
    int32 y = 2;
}

ctr Shapes {
    [16]byte hash = 1;      # byte fast path (memcpy)
    [4]int32 quad = 2;      # fixed-width element
    [3]string labels = 3;   # variable-size element
    [2]Point points = 4;    # fixed array of a container
    [3]Name aliases = 5;    # fixed array of a custom type
    [][3]int32 matrix = 6;  # nested: slice of fixed arrays
}


